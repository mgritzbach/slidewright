{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slidewright.dev/schemas/deck-spec-0.1.json",
  "title": "Slidewright deck specification",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "title", "slides"],
  "properties": {
    "version": { "const": "0.1" },
    "title": { "type": "string", "minLength": 1 },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "margin": { "type": "number", "minimum": 0 }
      }
    },
    "theme": { "type": "object" },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/hero" },
          { "$ref": "#/$defs/twoColumn" }
        ]
      }
    }
  },
  "$defs": {
    "runs": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["runs"],
          "properties": {
            "runs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["text"],
                "properties": {
                  "text": { "type": "string" },
                  "bold": { "type": "boolean" },
                  "italic": { "type": "boolean" },
                  "color": { "type": "string" }
                }
              }
            }
          }
        }
      ]
    },
    "hero": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout", "eyebrow", "title", "body", "callout"],
      "properties": {
        "id": { "type": "string" },
        "layout": { "const": "hero" },
        "eyebrow": { "type": "string", "minLength": 1 },
        "title": { "$ref": "#/$defs/runs" },
        "body": { "type": "string", "minLength": 1 },
        "callout": { "type": "string", "minLength": 1 }
      }
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "required": ["heading", "body"],
      "properties": {
        "heading": { "type": "string", "minLength": 1 },
        "body": { "type": "string", "minLength": 1 }
      }
    },
    "twoColumn": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout", "title", "left", "right"],
      "properties": {
        "id": { "type": "string" },
        "layout": { "const": "two-column" },
        "title": { "$ref": "#/$defs/runs" },
        "left": { "$ref": "#/$defs/column" },
        "right": { "$ref": "#/$defs/column" }
      }
    }
  }
}
