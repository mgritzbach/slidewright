{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slidewright.dev/schemas/deck-spec-0.1.json",
  "title": "Slidewright deck specification",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "title", "slides"],
  "properties": {
    "version": { "const": "0.1" },
    "title": { "type": "string", "minLength": 1 },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "margin": { "type": "number", "minimum": 0 } }
    },
    "theme": { "type": "object" },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topics"],
      "properties": {
        "topics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "title"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/hero" },
          { "$ref": "#/$defs/twoColumn" },
          { "$ref": "#/$defs/section" }
        ]
      }
    }
  },
  "$defs": {
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": { "type": "string" },
        "bold": { "type": "boolean" },
        "italic": { "type": "boolean" },
        "color": { "type": "string" }
      }
    },
    "text": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["runs"],
          "properties": {
            "runs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/run" } }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["paragraphs"],
          "properties": {
            "paragraphs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["runs"],
                "properties": {
                  "runs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/run" } },
                  "bullet": { "type": "boolean" },
                  "level": { "type": "integer", "minimum": 0, "maximum": 4 }
                }
              }
            }
          }
        }
      ]
    },
    "coverageFields": {
      "type": "object",
      "properties": {
        "topicId": { "type": "string", "minLength": 1 },
        "coverageRole": { "enum": ["divider", "substantive"] }
      }
    },
    "headlineSplit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ratio", "side"],
      "properties": {
        "ratio": { "enum": ["center", "two-thirds"] },
        "side": { "enum": ["left", "right"] }
      }
    },
    "hero": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout", "eyebrow", "title", "body", "callout"],
      "properties": {
        "id": { "type": "string" },
        "layout": { "const": "hero" },
        "topicId": { "type": "string", "minLength": 1 },
        "coverageRole": { "enum": ["divider", "substantive"] },
        "headlineSplit": { "$ref": "#/$defs/headlineSplit" },
        "eyebrow": { "type": "string", "minLength": 1 },
        "title": { "$ref": "#/$defs/text" },
        "body": { "$ref": "#/$defs/text" },
        "callout": { "$ref": "#/$defs/text" }
      }
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "required": ["heading", "body"],
      "properties": {
        "heading": { "type": "string", "minLength": 1 },
        "body": { "$ref": "#/$defs/text" }
      }
    },
    "twoColumn": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout", "title", "left", "right"],
      "properties": {
        "id": { "type": "string" },
        "layout": { "const": "two-column" },
        "topicId": { "type": "string", "minLength": 1 },
        "coverageRole": { "enum": ["divider", "substantive"] },
        "headlineSplit": { "$ref": "#/$defs/headlineSplit" },
        "columnGap": { "type": "number", "minimum": 16, "maximum": 96 },
        "title": { "$ref": "#/$defs/text" },
        "left": { "$ref": "#/$defs/column" },
        "right": { "$ref": "#/$defs/column" }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout", "title", "subtitle"],
      "properties": {
        "id": { "type": "string" },
        "layout": { "const": "section" },
        "topicId": { "type": "string", "minLength": 1 },
        "coverageRole": { "enum": ["divider", "substantive"] },
        "headlineSplit": { "$ref": "#/$defs/headlineSplit" },
        "title": { "$ref": "#/$defs/text" },
        "subtitle": { "$ref": "#/$defs/text" }
      }
    }
  }
}
