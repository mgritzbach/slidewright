{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slidewright.dev/schemas/c19-interop-suite-v2.schema.json",
  "title": "Slidewright C19 suite evidence v2",
  "type": "object",
  "required": [
    "schemaVersion",
    "evidenceOrigin",
    "contractHash",
    "suiteId",
    "attribution",
    "runner",
    "application",
    "automation",
    "sourceDeck",
    "resultDeck",
    "operation",
    "mutation",
    "semantic",
    "render"
  ],
  "properties": {
    "schemaVersion": { "const": "slidewright-c19-suite-evidence/v2" },
    "evidenceOrigin": { "const": "suite-runner" },
    "contractHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "suiteId": { "type": "string", "minLength": 1 },
    "attribution": {
      "type": "object",
      "required": ["repository", "sourceCommit", "sourceTreeClean", "hostPlatform", "hostArchitecture"],
      "properties": {
        "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "sourceTreeClean": { "const": true },
        "hostPlatform": { "type": "string", "minLength": 1 },
        "hostArchitecture": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "application": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "versionKind": { "type": "string" },
        "serviceBuildExposed": { "type": "boolean" },
        "serviceOrigins": { "type": "array", "items": { "type": "string", "format": "uri" } }
      },
      "additionalProperties": true
    },
    "automation": {
      "type": "object",
      "required": ["mode", "startedAt", "endedAt", "applicationLog", "trace"],
      "properties": {
        "mode": {
          "enum": ["desktop-automation", "browser-automation", "authenticated-service-automation"]
        },
        "protocol": { "type": "string", "minLength": 1 },
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" },
        "authenticated": { "type": "boolean" },
        "authentication": { "type": "object" },
        "browser": {
          "type": "object",
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          },
          "required": ["name", "version"],
          "additionalProperties": false
        },
        "applicationLog": { "$ref": "#/$defs/fileReceipt" },
        "trace": { "$ref": "#/$defs/fileReceipt" },
        "captureManifest": { "$ref": "#/$defs/fileReceipt" },
        "browserTrace": { "type": "object" },
        "browserEvidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/fileReceipt" }
        }
      },
      "additionalProperties": true
    },
    "sourceDeck": { "$ref": "#/$defs/deckReceipt" },
    "resultDeck": { "$ref": "#/$defs/deckReceipt" },
    "operation": {
      "type": "object",
      "required": ["opened", "imported", "saved", "reopened", "exported"],
      "properties": {
        "opened": { "const": true },
        "imported": { "const": true },
        "saved": { "const": true },
        "reopened": { "const": true },
        "exported": { "const": true }
      },
      "additionalProperties": false
    },
    "mutation": {
      "type": "object",
      "required": ["kind", "targetObjectId", "beforeSha256", "afterSha256", "reopenedNativeTextMatched", "report"],
      "properties": {
        "kind": { "const": "native-text-sentinel" },
        "targetObjectId": { "type": "string", "minLength": 1 },
        "beforeSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "afterSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "reopenedNativeTextMatched": { "const": true },
        "report": { "$ref": "#/$defs/fileReceipt" }
      },
      "additionalProperties": true
    },
    "semantic": {
      "type": "object",
      "required": ["sourceInventoryHash", "resultInventoryHash", "sourceInventory", "resultInventory", "coreChecks", "advancedChecks", "report"],
      "properties": {
        "sourceInventoryHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "resultInventoryHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "coreChecks": { "type": "array", "minItems": 5 },
        "advancedChecks": { "type": "array", "minItems": 5 },
        "report": { "$ref": "#/$defs/fileReceipt" }
      },
      "additionalProperties": true
    },
    "render": {
      "type": "object",
      "required": ["renderer", "report", "review", "slides"],
      "properties": {
        "renderer": {
          "type": "object",
          "required": ["name", "version"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        },
        "report": { "$ref": "#/$defs/fileReceipt" },
        "review": { "$ref": "#/$defs/fileReceipt" },
        "reviewAttestation": {
          "type": "object",
          "required": ["reviewMethod", "reviewedAt", "reviewerIdSha256", "reviewSha256", "slideCount", "allSlidesPassed"],
          "properties": {
            "reviewMethod": { "const": "full-size-human" },
            "reviewedAt": { "type": "string", "format": "date-time" },
            "reviewerIdSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "reviewSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "slideCount": { "type": "integer", "minimum": 1 },
            "allSlidesPassed": { "const": true }
          },
          "additionalProperties": false
        },
        "sourceDocument": { "$ref": "#/$defs/fileReceipt" },
        "slides": { "type": "array", "minItems": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "fileReceipt": {
      "type": "object",
      "required": ["path", "byteLength", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "byteLength": { "type": "integer", "minimum": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "deckReceipt": {
      "type": "object",
      "required": ["artifact", "slideCount", "inventoryHash"],
      "properties": {
        "artifact": { "$ref": "#/$defs/fileReceipt" },
        "slideCount": { "type": "integer", "minimum": 1 },
        "inventoryHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    }
  }
}
