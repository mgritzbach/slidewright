{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slidewright.dev/schemas/c19-interop-suite.schema.json",
  "title": "Slidewright C19 suite evidence",
  "type": "object",
  "required": [
    "schemaVersion",
    "evidenceOrigin",
    "contractHash",
    "suiteId",
    "attribution",
    "runner",
    "application",
    "automation",
    "sourceDeck",
    "resultDeck",
    "operation",
    "mutation",
    "semantic",
    "render"
  ],
  "properties": {
    "schemaVersion": { "const": "slidewright-c19-suite-evidence/v1" },
    "evidenceOrigin": { "const": "suite-runner" },
    "contractHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "suiteId": { "type": "string" },
    "attribution": {
      "type": "object",
      "required": ["repository", "sourceCommit", "sourceTreeClean", "hostPlatform", "hostArchitecture"],
      "properties": {
        "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "sourceTreeClean": { "const": true },
        "hostPlatform": { "type": "string" },
        "hostArchitecture": { "type": "string" }
      },
      "additionalProperties": true
    },
    "runner": {
      "type": "object",
      "required": ["id", "version", "command", "implementation"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "command": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "implementation": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fileReceipt" }
        }
      }
    },
    "sourceDeck": { "$ref": "#/$defs/deckReceipt" },
    "resultDeck": { "$ref": "#/$defs/deckReceipt" },
    "operation": {
      "type": "object",
      "required": ["opened", "imported", "saved", "reopened", "exported"],
      "properties": {
        "opened": { "const": true },
        "imported": { "const": true },
        "saved": { "const": true },
        "reopened": { "const": true },
        "exported": { "const": true }
      }
    },
    "mutation": {
      "type": "object",
      "required": ["kind", "targetObjectId", "beforeSha256", "afterSha256", "reopenedNativeTextMatched", "report"],
      "properties": {
        "kind": { "const": "native-text-sentinel" },
        "reopenedNativeTextMatched": { "const": true },
        "report": { "$ref": "#/$defs/fileReceipt" }
      }
    },
    "semantic": {
      "type": "object",
      "required": ["sourceInventoryHash", "resultInventoryHash", "sourceInventory", "resultInventory", "coreChecks", "advancedChecks", "report"],
      "properties": {
        "sourceInventoryHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "resultInventoryHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "coreChecks": { "type": "array", "minItems": 5 },
        "advancedChecks": { "type": "array", "minItems": 5 },
        "report": { "$ref": "#/$defs/fileReceipt" }
      }
    },
    "render": {
      "type": "object",
      "required": ["renderer", "report", "slides"],
      "properties": {
        "slides": { "type": "array", "minItems": 1 },
        "report": { "$ref": "#/$defs/fileReceipt" }
      }
    }
  },
  "$defs": {
    "fileReceipt": {
      "type": "object",
      "required": ["path", "byteLength", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "byteLength": { "type": "integer", "minimum": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "deckReceipt": {
      "type": "object",
      "required": ["artifact", "slideCount", "inventoryHash"],
      "properties": {
        "artifact": { "$ref": "#/$defs/fileReceipt" },
        "slideCount": { "type": "integer", "minimum": 1 },
        "inventoryHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}
