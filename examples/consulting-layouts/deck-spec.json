      "items": [
        { "id": "market", "label": "Market", "body": "Prioritize customers and define the value proposition." },
        { "id": "offer", "label": "Offer", "body": "Simplify the portfolio around defensible use cases." },
        { "id": "operations", "label": "Operations", "body": "Redesign processes, roles, and decision rights." },
        { "id": "enablers", "label": "Enablers", "body": "Align data, technology, talent, and governance." }
      ]
