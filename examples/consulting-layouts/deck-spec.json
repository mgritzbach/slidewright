        "heading": "Centralize when consistency creates value",
        "body": "Use common standards for scarce expertise, enterprise risk, shared data, and cross-business investment decisions."
      },
      "right": {
        "heading": "Localize when proximity creates value",
        "body": "Keep customer decisions, rapid experimentation, and market-specific trade-offs close to the operating teams."
      },
      "synthesis": { "runs": [ { "text": "Recommended model — ", "bold": true }, { "text": "centralize standards and platforms; localize customer-facing decisions within explicit guardrails.", "bold": false } ] }
