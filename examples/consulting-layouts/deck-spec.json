      "title": "Two conditions determine whether the program can scale",
      "items": [
        { "id": "demand", "label": "Demand", "body": "Users must experience a recurring problem with measurable urgency." },
        { "id": "delivery", "label": "Delivery", "body": "The operating model must solve that problem reliably at attractive cost." }
      ]
    },
    {
      "id": "three-points",
      "layout": "point-grid",
      "title": "Three moves convert the strategy into execution",
      "items": [
        { "id": "focus", "label": "Focus", "body": "Choose the segments where the advantage is strongest." },
        { "id": "build", "label": "Build", "body": "Concentrate resources on the few capabilities that matter." },
        { "id": "scale", "label": "Scale", "body": "Replicate the proven model with clear owners and measures." }
      ]
