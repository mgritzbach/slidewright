{
  "name": "slidewright-build-week",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Formatting-safe, editable PowerPoint generation for Codex",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgritzbach/slidewright.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "setup:runtime": "node scripts/setup-artifact-runtime.mjs",
    "runtime:benchmark": "node scripts/run-runtime-bootstrap-benchmark.mjs",
    "runtime:aggregate": "node scripts/aggregate-runtime-bootstrap-evidence.mjs",
    "preflight": "node packages/cli/src/cli.mjs preflight --out outputs/preflight.json",
    "demo:compile": "node packages/cli/src/cli.mjs compile examples/demo/deck-spec.json --out outputs/demo/plan.json",
    "demo:fonts": "node packages/cli/src/cli.mjs fonts outputs/demo/plan.json --out outputs/demo/font-report.json",
    "demo:lint": "node packages/cli/src/cli.mjs lint outputs/demo/plan.json --out outputs/demo/lint-report.json",
    "demo:render": "npm run setup:runtime && node packages/cli/src/cli.mjs render outputs/demo/plan.json --out outputs/demo/slidewright-demo.pptx --preview-dir outputs/demo/previews",
    "demo:audit": "python plugins/slidewright/skills/slidewright/scripts/audit_pptx.py outputs/demo/slidewright-demo.pptx --json outputs/demo/ooxml-audit.json",
    "demo": "npm test && npm run demo:compile && npm run demo:fonts && npm run demo:lint && npm run demo:render && npm run demo:audit",
    "fidelity": "node scripts/run-fidelity-benchmark.mjs",
    "mutation": "node scripts/run-copy-mutation.mjs",
    "copy-resilience": "npm run setup:runtime && node scripts/run-copy-resilience-benchmark.mjs",
    "copy-resilience:verify": "node scripts/verify-copy-resilience-evidence.mjs",
    "copy-resilience:review": "node scripts/finalize-copy-resilience-review.mjs",
    "repair": "node scripts/run-repair-benchmark.mjs",
    "font-integrity": "node scripts/run-font-integrity-benchmark.mjs",
    "font-integrity:verify": "node scripts/verify-font-integrity-evidence.mjs",
    "professional-quality:prepare": "node scripts/build-professional-quality-review-pack.mjs",
    "professional-quality:verify": "node scripts/verify-professional-quality-evidence.mjs",
    "professional-quality:require-complete": "node scripts/verify-professional-quality-evidence.mjs --require-complete",
    "structural-ingestion": "node scripts/run-structural-ingestion-benchmark.mjs",
    "structural-ingestion:verify": "node scripts/verify-structural-ingestion-evidence.mjs",
    "interoperability:status": "node scripts/run-c19-interoperability-benchmark.mjs",
    "interoperability:libreoffice": "node scripts/c19/run_libreoffice_suite.mjs",
    "interoperability:verify": "node scripts/verify-c19-interop-evidence.mjs",
    "repair-free": "node scripts/run-repair-free-benchmark.mjs",
    "repair-free:reuse": "node scripts/run-repair-free-benchmark.mjs --allow-dirty --reuse-release-outputs",
    "repair-free:verify": "node scripts/verify-repair-free-evidence.mjs",
    "repair-free:verify:development": "node scripts/verify-repair-free-evidence.mjs --development",
    "ingestion": "node scripts/run-independent-ingestion.mjs",
    "template": "node scripts/run-template-preservation.mjs",
    "template:matrix": "node scripts/run-template-matrix-benchmark.mjs",
    "template:matrix:review": "node scripts/finalize-template-matrix-review.mjs",
    "template:matrix:verify": "node scripts/verify-template-matrix-evidence.mjs",
    "template:matrix:publish": "node scripts/publish-template-matrix-evidence.mjs",
    "template:matrix:verify:published": "node scripts/verify-template-matrix-public-evidence.mjs",
    "submission:prepare": "node scripts/build-submission-package.mjs && node submission/check-submission.mjs --local-only",
    "submission:check": "node submission/check-submission.mjs",
    "defects": "npm run setup:runtime && node scripts/run-defect-benchmark.mjs",
    "powerpoint:adapter": "node scripts/run-powerpoint-adapter.mjs",
    "iteration": "node scripts/run-fine-grained-iteration.mjs",
    "design-profile": "node scripts/run-design-profile-benchmark.mjs",
    "semantic-surface": "npm run setup:runtime && node scripts/run-semantic-surface-benchmark.mjs",
    "semantic-mutation": "npm run setup:runtime && node scripts/run-semantic-mutation-benchmark.mjs",
    "semantic-mutation:review": "node scripts/finalize-semantic-mutation-review.mjs",
    "prompt-robustness": "npm run setup:runtime && node scripts/run-prompt-robustness-benchmark.mjs",
    "prompt-robustness:review": "node scripts/finalize-prompt-robustness-review.mjs",
    "executive-review": "npm run setup:runtime && node scripts/run-executive-review-demo.mjs",
    "verify:fidelity": "node packages/cli/src/cli.mjs verify outputs/fidelity/slidewright-fidelity-benchmark.pptx --out outputs/fidelity/delivery-manifest.json --preview-dir outputs/fidelity/slidewright-fidelity-benchmark --montage outputs/fidelity/slidewright-fidelity-montage.png --handoff outputs/fidelity/DELIVERY.md --require-bundle",
    "release:check": "npm run preflight && npm run runtime:benchmark && npm run demo && npm run universal-design && npm run emphasis-pattern && npm run fidelity && npm run mutation && npm run repair && npm run font-integrity && npm run font-integrity:verify && npm run professional-quality:prepare && npm run professional-quality:verify && npm run copy-resilience && npm run copy-resilience:verify && npm run ingestion && npm run template && npm run structural-ingestion && npm run structural-ingestion:verify && npm run defects && npm run powerpoint:adapter && npm run iteration && npm run design-profile && npm run feedback-contract && npm run prompt-robustness && npm run semantic-surface && npm run semantic-mutation && npm run repair-free && npm run repair-free:verify && npm run evidence:verify",
    "feedback-contract": "node scripts/run-feedback-contract-benchmark.mjs",
    "universal-design": "npm run setup:runtime && node scripts/run-universal-design-benchmark.mjs",
    "emphasis-pattern": "npm run setup:runtime && node scripts/run-emphasis-pattern-benchmark.mjs",
    "consulting-layouts:compile": "node packages/cli/src/cli.mjs compile examples/consulting-layouts/deck-spec.json --out outputs/consulting-layouts/plan.json",
    "consulting-layouts:lint": "node packages/cli/src/cli.mjs lint outputs/consulting-layouts/plan.json --out outputs/consulting-layouts/lint-report.json",
    "consulting-layouts:render": "npm run setup:runtime && node packages/cli/src/cli.mjs render outputs/consulting-layouts/plan.json --out outputs/consulting-layouts/slidewright-consulting-layouts.pptx --preview-dir outputs/consulting-layouts/previews",
    "consulting-layouts:audit": "python plugins/slidewright/skills/slidewright/scripts/audit_pptx.py outputs/consulting-layouts/slidewright-consulting-layouts.pptx --json outputs/consulting-layouts/ooxml-audit.json",
    "consulting-layouts": "npm run consulting-layouts:compile && npm run consulting-layouts:lint && npm run consulting-layouts:render && npm run consulting-layouts:audit",
    "evidence:publish": "node scripts/publish-public-evidence.mjs",
    "evidence:verify": "node scripts/verify-public-evidence.mjs",
    "evidence:ci": "node scripts/run-public-evidence-ci.mjs",
    "evidence:aggregate": "node scripts/aggregate-public-evidence.mjs"
  },
  "peerDependencies": {
    "@oai/artifact-tool": "*"
  },
  "peerDependenciesMeta": {
    "@oai/artifact-tool": {
      "optional": true
    }
  }
}
